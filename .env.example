# ── Prep Max backend environment ────────────────────────────────────────────
# Copy to `.env` and fill in. `.env` is gitignored — never commit real secrets.

# ── Database (you create the DB in pgAdmin; give the details here) ───────────
# The SUPERUSER / admin connection — used ONCE by `npm run db:setup` to create
# the least-privilege app role and grant it rights. Not used at runtime.
PGADMIN_HOST=localhost
PGADMIN_PORT=5432
PGADMIN_DATABASE=prep_max
PGADMIN_USER=postgres
PGADMIN_PASSWORD=postgres

# The APPLICATION connection — a least-privilege role created by db:setup.
# The app connects ONLY as this role at runtime (it cannot bypass RLS).
# Pick any password you like here; db:setup creates the role with it.
APP_DB_HOST=localhost
APP_DB_PORT=5432
APP_DB_DATABASE=prep_max
APP_DB_USER=prep_app
APP_DB_PASSWORD=postgres

# ── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Auth ────────────────────────────────────────────────────────────────────
# Long random string for signing session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=change-me-to-a-long-random-string
