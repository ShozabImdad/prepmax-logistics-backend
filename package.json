{
  "name": "prep-max-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Prep Max Logistics — backend (Express + PostgreSQL, branch-isolated via RLS)",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "migrate": "tsx src/scripts/migrate.ts",
    "migrate:status": "tsx src/scripts/migrate.ts status",
    "db:setup": "tsx src/scripts/setup-roles.ts",
    "seed": "tsx src/scripts/seed.ts",
    "poll": "tsx src/tracking/poller.ts",
    "test": "tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "argon2": "^0.41.1",
    "bwip-js": "^4.11.2",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "nanoid": "^5.0.9",
    "nodemailer": "^9.0.3",
    "patchright": "^1.61.1",
    "pg": "^8.13.1",
    "uuidv7": "^1.0.2",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
